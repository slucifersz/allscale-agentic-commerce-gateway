# Local Anvil example. Do not commit real secrets in .env files.
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
NETWORK_NAME=Local Anvil

# Required for deployment and local auto-pay flows.
DEPLOYER_PRIVATE_KEY=
GATEWAY_SIGNER_PRIVATE_KEY=
DEMO_AGENT_PRIVATE_KEY=

# Optional. If omitted, deploy script derives these from the provided keys.
GATEWAY_SIGNER_ADDRESS=
DEMO_AGENT_ADDRESS=
DEMO_MERCHANT_TREASURY=

# HashKey testnet deployment.
HASHKEY_TESTNET_RPC_URL=
HASHKEY_TESTNET_DEPLOYER_PRIVATE_KEY=
HASHKEY_TESTNET_CHAIN_ID=133

# Explorer base URL used for completed order links.
EXPLORER_BASE_URL=https://testnet-explorer.hsk.xyz

# Optional token override. Leave unset to use deployments/*.json token records.
TOKEN_SYMBOL=mUSDC
TOKEN_ADDRESS=
TOKEN_DECIMALS=6

# --- HashKey Chain Mainnet (chainId 177) ---
# Private keys must be filled via scripts/setup-mainnet-secrets.sh, never
# committed. The Merchant Treasury private key is never needed by this repo.
HASHKEY_MAINNET_RPC_URL=https://mainnet.hsk.xyz
HASHKEY_MAINNET_CHAIN_ID=177
HASHKEY_MAINNET_DEPLOYER_ADDRESS=
HASHKEY_MAINNET_DEPLOYER_PRIVATE_KEY=
DEMO_MERCHANT_TREASURY=
# Real bridged USDC on HashKey mainnet; mock tokens are forbidden on mainnet.
TOKEN_IS_MOCK=false
DEPLOY_MOCK_TOKEN=false
SPENDING_LIMIT_TOKEN_UNITS=1
AUTO_APPROVE=false
APPROVAL_TOKEN_UNITS=1
DEPLOYMENT_FILE=
# Demo API checkout/order/tx-dedup state. Use :memory: only for tests.
DEMO_STATE_FILE=.data/demo-state.json
