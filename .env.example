# Local Anvil example. Do not commit real secrets in .env files.
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
NETWORK_NAME=Local Anvil

# Required for deployment and local auto-pay flows.
DEPLOYER_PRIVATE_KEY=
GATEWAY_SIGNER_PRIVATE_KEY=
DEMO_AGENT_PRIVATE_KEY=

# Optional. If omitted, deploy script derives these from the provided keys.
GATEWAY_SIGNER_ADDRESS=
DEMO_AGENT_ADDRESS=
DEMO_MERCHANT_TREASURY=

# HashKey testnet deployment.
HASHKEY_TESTNET_RPC_URL=
HASHKEY_TESTNET_DEPLOYER_PRIVATE_KEY=
HASHKEY_TESTNET_CHAIN_ID=133

# Explorer base URL used for completed order links.
EXPLORER_BASE_URL=https://testnet-explorer.hsk.xyz

# Optional token override. Leave unset to use deployments/*.json token records.
TOKEN_SYMBOL=mUSDC
TOKEN_ADDRESS=
TOKEN_DECIMALS=6
